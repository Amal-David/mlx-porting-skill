{
  "name": "mlx-model-advisor-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:data": "node scripts/build-skill-data.mjs",
    "check:data": "node scripts/build-skill-data.mjs --check",
    "typecheck": "tsc --noEmit",
    "build": "npm run build:data && npm run typecheck",
    "smoke:local": "node scripts/smoke-local.mjs",
    "dev": "npm run build:data && wrangler dev --local --port 8787",
    "deploy": "npm run build:data && wrangler deploy"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250628.0",
    "@types/node": "^24.0.4",
    "typescript": "^5.8.3",
    "wrangler": "^4.22.0"
  }
}
