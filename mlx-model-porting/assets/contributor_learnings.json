      "evidence": [
        "dgrauet/ltx-2-mlx block_streaming.py shows memory-mapped safetensors, per-block key maps, shared block rebinding, eviction, and reload.",
        "dgrauet/ltx-2-mlx tests assert block discovery, weight binding, eager-versus-streamed output equality, and eviction/reload consistency.",
        "dgrauet/ltx-2-mlx regression report records byte-identical low-RAM versus eager output for a q8 LTX-2 path."
      ],
      "porting_skill_change": "Add a proven-mlx-port optimization method for block weight streaming from inspectable safetensors, scoped to repeated-block models that exceed unified-memory budget.",
      "validation_gate": "Block-count/key coverage, streamed-vs-eager parity on a tiny fixture, eviction/reload test, peak-memory measurement, and fallback eager path.",
      "rollback_condition": "Disable streaming if outputs drift, block key coverage is incomplete, eviction reloads stale weights, or disk/page-fault overhead erases the memory benefit."
    },
