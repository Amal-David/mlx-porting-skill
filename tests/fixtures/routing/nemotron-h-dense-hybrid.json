  "expected_status": "recommended",
  "expected_primary_family": "ssm-recurrent-hybrid",
  "expected_families": [
    "ssm-recurrent-hybrid",
    "dense-decoder-transformer"
  ],
  "expected_runbooks": [
    "references/runbook-ssm-hybrid.md",
    "references/runbook-decoder-transformer.md"
  ],
  "expected_traits": [
